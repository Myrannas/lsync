{
  "name": "lfsync",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:packages": "vp run --filter './packages/*' build",
    "docs:api": "typedoc",
    "docs:build": "typedoc && vitepress build docs && node scripts/verify-docs.ts",
    "docs:dev": "typedoc && vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "docs:verify": "node scripts/verify-docs.ts",
    "dev:worker": "corepack pnpm --filter @lfsync/example-worker dev",
    "dev:react": "corepack pnpm --filter @lfsync/example-react dev",
    "e2e": "vp test run --config apps/integration-tests/vite.config.ts apps/integration-tests/test/smoke.e2e.ts",
    "publish:packages": "vp run build:packages && node scripts/publish-packages.ts",
    "publish:packages:dry-run": "vp run build:packages && node scripts/publish-packages.ts --dry-run",
    "prepare": "vp config",
    "version:packages": "node scripts/version-packages.ts"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.44.1",
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "typedoc": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitepress": "catalog:",
    "vue": "catalog:"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2"
    },
    "peerDependencyRules": {
      "allowAny": [
        "vite"
      ],
      "allowedVersions": {
        "vite": "*"
      }
    }
  }
}
