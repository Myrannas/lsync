{
  "$schema": "https://typedoc.org/schema.json",
  "name": "lsync API",
  "entryPoints": [
    "packages/definition/src/index.ts",
    "packages/server/src/index.ts",
    "packages/server/src/client.ts",
    "packages/tanstack-db/src/index.ts",
    "packages/transport/src/index.ts"
  ],
  "entryPointStrategy": "resolve",
  "tsconfig": "tsconfig.typedoc.json",
  "out": "docs/public/api/reference/generated",
  "readme": "none",
  "excludePrivate": true,
  "excludeProtected": true,
  "includeVersion": false,
  "navigation": {
    "includeGroups": true,
    "includeFolders": false
  },
  "visibilityFilters": {
    "protected": false,
    "private": false,
    "inherited": true,
    "external": false
  }
}
