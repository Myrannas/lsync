{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "paths": {
      "lsync-server": ["./packages/server/src/index.ts"],
      "lsync-server/client": ["./packages/server/src/client.ts"],
      "lsync-tanstack-db": ["./packages/tanstack-db/src/index.ts"],
      "lsync-transport": ["./packages/transport/src/index.ts"]
    }
  }
}
